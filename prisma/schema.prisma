generator client {
  provider = "prisma-client-js"
} 

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. הגדרת Enums (ערכים קבועים) כפי שנדרש באפיון
enum PlayStatus {
  Waiting
  Live
  Finished
}

enum ParticipantRole {
  Admin
  Player
}

// 2. מודל משתמש
model User {
  id           Int               @id @default(autoincrement())
  username     String            @unique 
  participants PlayParticipant[] // קשר למפגשים שהמשתמש משתתף בהם
}

// 3. מודל הפעילות
model Play {
  id           Int               @id @default(autoincrement())
  status       PlayStatus        @default(Waiting) // סטטוס ברירת מחדל
  participants PlayParticipant[] // קשר למשתתפים
}

// 4. טבלת קשר (Many-to-Many)
model PlayParticipant {
  id     Int               @id @default(autoincrement()) 
  role   ParticipantRole   @default(Player) // תפקיד ברירת מחדל
  score  Int               @default(0)      // ניקוד
  
  // קשרים למודלים האחרים
  userId Int
  user   User @relation(fields: [userId], references: [id])
  
  playId Int
  play   Play @relation(fields: [playId], references: [id])

  @@unique([userId, playId]) // מונע ממשתמש להירשם פעמיים לאותו מופע
}
