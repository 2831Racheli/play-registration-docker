generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// עדכון ה-Enum ל-PlayStatus
enum PlayStatus {
  Waiting
  Live
  Finished
}

enum ParticipantRole {
  Admin
  Player
}

model User {
  id           Int               @id @default(autoincrement())
  username     String            @unique
  participants PlayParticipant[] // קשר מעודכן
}

// המודל הראשי שונה ל-Play
model Play {
  id           Int               @id @default(autoincrement())
  status       PlayStatus        @default(Waiting)
  participants PlayParticipant[]
}

// טבלת הקשר שונתה ל-PlayParticipant
model PlayParticipant {
  id     Int               @id @default(autoincrement())
  role   ParticipantRole   @default(Player)
  score  Int               @default(0)
  
  userId Int
  user   User @relation(fields: [userId], references: [id])
  
  playId Int
  play   Play @relation(fields: [playId], references: [id])

  @@unique([userId, playId])
}
